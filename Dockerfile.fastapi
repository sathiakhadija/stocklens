FROM python:3.12-slim

WORKDIR /app

COPY requirements.txt requirements-api.txt ./
RUN pip install --no-cache-dir -r requirements.txt -r requirements-api.txt

COPY . /app

ENV PYTHONPATH=/app/src/core:/app

RUN mkdir -p /app/db
COPY db/stocklens.db /app/db/stocklens.db

EXPOSE 8000

CMD ["uvicorn", "api_service.main:app", "--host", "0.0.0.0", "--port", "8000", "--workers", "2"]
